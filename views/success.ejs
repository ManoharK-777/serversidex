<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Link Established | ServerSide X</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- CSS -->
    <link rel="stylesheet" href="/style.css">
</head>
<body class="success-page">
    <!-- Custom Cursor -->
    <div class="cursor-glow" id="cursorGlow"></div>
    <div class="cursor-dot" id="cursorDot"></div>

    <!-- Background Elements -->
    <canvas id="particleCanvas"></canvas>
    <div class="ambient-orb orb-1"></div>
    <div class="ambient-orb orb-2"></div>

    <main class="dashboard-wrapper center-content">
        <section class="reveal">
            <div class="glass-card success-card tilt-element">
                <div class="success-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                </div>
                <h1 class="success-title">Connection Successful</h1>
                <p class="success-greeting">Welcome to the inner ring, <span class="highlight-name"><%= name %></span> 🚀</p>
                <p class="success-message">Your transmission has been securely received by our mainframes and forwarded to the administrator.</p>
                
                <a href="/" class="neon-btn back-btn">
                    <span class="btn-light-sweep"></span>
                    <span class="btn-text">Return to Dashboard</span>
                </a>
            </div>
        </section>
    </main>

    <!-- JS -->
    <script src="/script.js"></script>
</body>
</html>
